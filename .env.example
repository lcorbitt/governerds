# Copy this file to .env.local and fill in the values. Never commit secrets.
# .env.local is gitignored.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=local
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase
# Local defaults are printed by `npm run supabase:start`.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54521
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Supabase OAuth (Google + Microsoft). Configure in the dashboard per project.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
SUPABASE_AUTH_AZURE_CLIENT_ID=
SUPABASE_AUTH_AZURE_SECRET=

# ---------------------------------------------------------------------------
# Leave blank locally (no local Redis server). To test Redis, use a separate
# dev Upstash database URL + read/write token — never prod creds, never "local".
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Email (Resend) — free tier. Leave RESEND_API_KEY blank to log instead of send.
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="GoverNerds <onboarding@resend.dev>"

# ---------------------------------------------------------------------------
# Events / background jobs (Inngest) — free tier.
# INNGEST_EVENT_KEY is used by both Next.js (events.publish) and Edge
# Functions (publishEvent). Export it in your shell when running
# `supabase functions serve`, or set it via `supabase secrets set` in deployed
# environments.
#
# For end-to-end local event delivery, use `npm run dev:local` — it sets
# INNGEST_EVENT_KEY=local and starts the Inngest dev server automatically.
# ---------------------------------------------------------------------------
JOB_PROVIDER=inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Analytics (PostHog) — free tier. Set ANALYTICS_PROVIDER=posthog to enable.
# ---------------------------------------------------------------------------
ANALYTICS_PROVIDER=none
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# Monitoring (Sentry) — free tier. Leave blank to disable.
# ---------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
